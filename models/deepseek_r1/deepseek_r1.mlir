// deepseek_r1.mlir — BuddyRuntime DeepSeekR1 manifest (fp32 variant)
//
// TODO: this file should be generated by Graph Frontend.
//
// This is the RHAL dialect representation of the DeepSeekR1 execution manifest.
// It replaces the old custom-text deepseek_r1.rhal format.
//
// Pack into .rax with:
//   rax-pack deepseek_r1.mlir -o deepseek_r1.rax
//
// Then run:
//   buddy-cli --model deepseek_r1.rax --prompt "Hello"
//
// URI resolution: "file:X" means X is resolved relative to the directory of
// the .rax file.  Place deepseek_r1.rax, deepseek_r1_model.so, arg0.data,
// and vocab.txt all in the same directory (or use absolute paths).
//
// Model shapes:
//   - batch size:  1
//   - max seq len: 1024
//   - KV heads:    2
//   - KV hidden:   128
//   - vocab size:  151936  (Qwen tokenizer, EOS = 151643)
//   - KV layers:   56

rhal.module @deepseek_r1 attributes {
    version = "0.1.0",
    model_name = "deepseek_r1_fp32",
    vocab_uri = "file:vocab.txt"} {

  // ── External constants (not inlined in .rax, resolved at load time) ────────
  // ~7 GB weight tensor, mapped by mmap; uri is relative to the .rax file.
  rhal.constant @weights {id = 1 : i32, storage = "external",
                           type = tensor<1777088064xf32>,
                           uri = "file:arg0.data"}

  // ── Code object: one .so providing both prefill and decode kernels ──────────
  // entry = "" because function symbols are resolved by dlsym inside
  // ModelSession using the _mlir_ciface_forward_{prefill,decode} convention.
  rhal.codeobj @model_kernels {id = 1 : i32, kind = "host_shared_lib",
                                backend = "cpu",
                                uri = "file:deepseek_r1_model.so"}

  // ── Buffer descriptors ──────────────────────────────────────────────────────

  // Prefill input: prompt token sequence
  rhal.buffer @prefill_tokens {space = "host", type = tensor<1x1024xi64>}

  // Decode inputs: single new token + current sequence position
  rhal.buffer @decode_token   {space = "host", type = tensor<1x1xi64>}
  rhal.buffer @cache_position {space = "host", type = tensor<1xi64>}

  // KV cache — 56 layers, shape: {batch=1, heads=2, maxLen=1024, hidden=128}
  rhal.buffer @kv0  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv1  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv2  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv3  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv4  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv5  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv6  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv7  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv8  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv9  {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv10 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv11 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv12 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv13 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv14 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv15 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv16 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv17 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv18 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv19 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv20 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv21 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv22 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv23 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv24 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv25 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv26 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv27 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv28 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv29 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv30 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv31 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv32 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv33 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv34 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv35 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv36 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv37 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv38 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv39 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv40 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv41 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv42 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv43 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv44 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv45 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv46 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv47 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv48 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv49 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv50 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv51 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv52 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv53 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv54 {space = "dram", type = tensor<1x2x1024x128xf32>}
  rhal.buffer @kv55 {space = "dram", type = tensor<1x2x1024x128xf32>}

  // Logits outputs (batch=1, seq/1, vocab=151936)
  rhal.buffer @logits_prefill {space = "host", type = tensor<1x1024x151936xf32>}
  rhal.buffer @logits_decode  {space = "host", type = tensor<1x1x151936xf32>}

  // ── Function ABI contracts ──────────────────────────────────────────────────

  rhal.func @forward_prefill {
    inputs   = ["prefill_tokens"],
    outputs  = ["logits_prefill"],
    dispatch = "model_kernels",
    args     = ["prefill_tokens",
                "kv0",  "kv1",  "kv2",  "kv3",  "kv4",  "kv5",  "kv6",  "kv7",
                "kv8",  "kv9",  "kv10", "kv11", "kv12", "kv13", "kv14", "kv15",
                "kv16", "kv17", "kv18", "kv19", "kv20", "kv21", "kv22", "kv23",
                "kv24", "kv25", "kv26", "kv27", "kv28", "kv29", "kv30", "kv31",
                "kv32", "kv33", "kv34", "kv35", "kv36", "kv37", "kv38", "kv39",
                "kv40", "kv41", "kv42", "kv43", "kv44", "kv45", "kv46", "kv47",
                "kv48", "kv49", "kv50", "kv51", "kv52", "kv53", "kv54", "kv55",
                "logits_prefill"]}

  rhal.func @forward_decode {
    inputs   = ["decode_token", "cache_position"],
    outputs  = ["logits_decode"],
    dispatch = "model_kernels",
    args     = ["decode_token", "cache_position",
                "kv0",  "kv1",  "kv2",  "kv3",  "kv4",  "kv5",  "kv6",  "kv7",
                "kv8",  "kv9",  "kv10", "kv11", "kv12", "kv13", "kv14", "kv15",
                "kv16", "kv17", "kv18", "kv19", "kv20", "kv21", "kv22", "kv23",
                "kv24", "kv25", "kv26", "kv27", "kv28", "kv29", "kv30", "kv31",
                "kv32", "kv33", "kv34", "kv35", "kv36", "kv37", "kv38", "kv39",
                "kv40", "kv41", "kv42", "kv43", "kv44", "kv45", "kv46", "kv47",
                "kv48", "kv49", "kv50", "kv51", "kv52", "kv53", "kv54", "kv55",
                "logits_decode"]}
}
