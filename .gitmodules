[submodule "llvm"]
	path = llvm
	url = https://github.com/RuyiAI-Stack/llvm-project
	branch = riscv
	shallow = true
[submodule "thirdparty/mimalloc"]
	path = thirdparty/mimalloc
	url = https://github.com/microsoft/mimalloc.git
	shallow = false
[submodule "thirdparty/riscv-gnu-toolchain"]
	path = thirdparty/riscv-gnu-toolchain
	url = https://github.com/riscv-collab/riscv-gnu-toolchain.git
	shallow = false
[submodule "thirdparty/tt-mlir"]
	path = thirdparty/tt-mlir
	url = https://github.com/tenstorrent/tt-mlir.git
	shallow = false
